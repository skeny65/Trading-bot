# Alpaca
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets/v2

# ngrok
NGROK_AUTH_TOKEN=your_ngrok_auth_token_here
NGROK_DOMAIN=your-ngrok-domain.ngrok-free.dev

# GitHub (para Claude Routine)
GITHUB_TOKEN=github_pat_your_token_here
GITHUB_REPO=your_username/Trading-bot

# GitHub Polling (Fondo)
github_token=ghp_your_polling_token_here

# Bot Manager
BOT_MANAGER_ENABLED=true
DAILY_RUN_TIME=10:00
EXECUTE_ORDERS=false              # false = dry run (simulación), true = live trading
DRY_RUN_INITIAL_BALANCE=100000    # balance ficticio para simulación

# Notificaciones
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
NOTIFY_ON_PAUSE=true
NOTIFY_ON_REACTIVATE=true
NOTIFY_ON_SIGNAL_REJECTED=true
NOTIFY_ON_ORDER_ERROR=true
NOTIFY_ON_CRITICAL_DRAWDOWN=true
CRITICAL_DRAWDOWN_THRESHOLD=-25
SEND_DAILY_SUMMARY=true

# Umbrales (sobreescriben config.py)
THRESHOLD_WR_PAUSE=45
THRESHOLD_DD_PAUSE=-20
THRESHOLD_PF_PAUSE=1.05
THRESHOLD_WR_REACTIVATE=52

# Server and Security
PORT=8000
WEBHOOK_SECRET=a_secure_random_string