# Alpaca
ALPACA_API_KEY=PK_xxxxxxxxxxxx
ALPACA_SECRET_KEY=xxxxxxxxxxxx
ALPACA_BASE_URL=https://paper-api.alpaca.markets  # o live

# ngrok
NGROK_AUTH_TOKEN=xxxxxxxxxxxx
NGROK_DOMAIN=tu-dominio.ngrok.io

# GitHub (para Claude Routine)
GITHUB_TOKEN=ghp_xxxxxxxxxxxx
GITHUB_REPO=tu-usuario/trading-strategies

# Bot Manager
BOT_MANAGER_ENABLED=true
DAILY_RUN_TIME=10:00
EXECUTE_DECISIONS=false  # true = ejecuta pausas/reactivaciones

# Notificaciones
TELEGRAM_BOT_TOKEN=xxxxxxxxxxxx
TELEGRAM_CHAT_ID=xxxxxxxxxxxx

# Umbrales (sobreescriben config.py)
THRESHOLD_WR_PAUSE=45
THRESHOLD_DD_PAUSE=-20
THRESHOLD_PF_PAUSE=1.05
THRESHOLD_WR_REACTIVATE=52

# Server and Security
PORT=8000
WEBHOOK_SECRET=a_secure_random_string